# OMENORA Environment Configuration
# Copy this file to .env and fill in your actual values

# AI Service
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE

# Payment Processing (Stripe)
# Use test keys for development, live keys for production
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY_HERE
STRIPE_PUBLISHABLE_KEY=YOUR_STRIPE_PUBLISHABLE_KEY_HERE
NUXT_PUBLIC_STRIPE_KEY=YOUR_STRIPE_PUBLISHABLE_KEY_HERE
STRIPE_DAILY_PRICE_ID=YOUR_STRIPE_PRICE_ID_HERE

# Database (Supabase)
SUPABASE_URL=YOUR_SUPABASE_URL_HERE
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE
SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_KEY_HERE

# Email Service (Resend)
RESEND_API_KEY=YOUR_RESEND_API_KEY_HERE

# Public Site URL (update for production)
NUXT_PUBLIC_SITE_URL=https://omenora.com

# Optional: Sentry DSN for error tracking
# SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@xxxxxxx.ingest.sentry.io/xxxxxxx
# SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SENTRY_ORG=your-org-name
# SENTRY_PROJECT=omenora

# Stripe Webhook (for production webhooks)
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Additional Stripe Price IDs for production
# STRIPE_BASIC_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx
# STRIPE_BUNDLE_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx
# STRIPE_ORACLE_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx
