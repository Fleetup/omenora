# OMENORA Environment Configuration
# Copy this file to .env and fill in your actual values
#
# IMPORTANT: Nuxt 3 runtime config reads env vars with the NUXT_ prefix convention:
#   - Private (server-only) config: NUXT_<KEY_IN_SCREAMING_SNAKE_CASE>
#   - Public (client+server) config: NUXT_PUBLIC_<KEY_IN_SCREAMING_SNAKE_CASE>
# Variables without the correct prefix are silently ignored at runtime.

# AI Service (private — server only)
NUXT_ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE

# Payment Processing — Stripe
# Use test keys for development, live keys for production
NUXT_STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY_HERE
NUXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=YOUR_STRIPE_PUBLISHABLE_KEY_HERE
NUXT_STRIPE_DAILY_PRICE_ID=YOUR_STRIPE_PRICE_ID_HERE
NUXT_STRIPE_COMPAT_PLUS_PRICE_ID=YOUR_COMPAT_PLUS_PRICE_ID_HERE
NUXT_STRIPE_COMPAT_SINGLE_PRICE_ID=YOUR_COMPAT_SINGLE_PRICE_ID_HERE

# Database — Supabase
# NUXT_SUPABASE_URL is server-only (service role); NUXT_PUBLIC_SUPABASE_URL is client+server (anon role)
NUXT_SUPABASE_URL=YOUR_SUPABASE_URL_HERE
NUXT_PUBLIC_SUPABASE_URL=YOUR_SUPABASE_URL_HERE
NUXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE
NUXT_SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_KEY_HERE

# Email Service — Resend (private — server only)
NUXT_RESEND_API_KEY=YOUR_RESEND_API_KEY_HERE

# Public Site URL (update for production)
NUXT_PUBLIC_SITE_URL=https://omenora.com

# Analytics Pixel IDs (optional — analytics are skipped if not set)
NUXT_PUBLIC_TIKTOK_PIXEL_ID=your_tiktok_pixel_id_here
NUXT_PUBLIC_META_PIXEL_ID=your_meta_pixel_id_here

# Optional: Sentry DSN for error tracking
# SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@xxxxxxx.ingest.sentry.io/xxxxxxx
# SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SENTRY_ORG=your-org-name
# SENTRY_PROJECT=omenora

# Stripe Webhook (required — create in Stripe Dashboard > Webhooks)
NUXT_STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Resend Webhook signing secret (required — copy from Resend Dashboard > Webhooks > signing secret)
# The endpoint reads this via process.env.RESEND_WEBHOOK_SECRET (no NUXT_ prefix needed at runtime).
# Note: Resend signing secrets start with "whsec_" just like Stripe.
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Redis (Railway Redis add-on — required for multi-instance rate limiting)
# Format: redis://:password@host:port
NUXT_REDIS_URL=redis://:password@containers-us-west-xxx.railway.app:6379

# Email Job Queue Secret (generate with: openssl rand -hex 32)
# Must match the x-job-secret header sent by Railway cron
NUXT_EMAIL_JOB_SECRET=your_random_secret_here

# Inngest — background job platform (https://inngest.com)
# The SDK reads INNGEST_EVENT_KEY and INNGEST_SIGNING_KEY natively (no NUXT_ prefix needed).
# NUXT_-prefixed variants populate runtimeConfig but are not required by the SDK itself.
# In local dev with `npx inngest-cli@latest dev`, both keys can be left unset.
INNGEST_EVENT_KEY=your_inngest_event_key_here
INNGEST_SIGNING_KEY=signkey-prod-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Additional Stripe Price IDs for production
# NUXT_STRIPE_BASIC_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx
# NUXT_STRIPE_BUNDLE_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx
# NUXT_STRIPE_ORACLE_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx
