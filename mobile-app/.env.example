# OMENORA Mobile App — Environment Configuration
# Copy this file to .env and fill in your values

# API Backend URL
# Production (default if not set):
EXPO_PUBLIC_API_BASE_URL=https://api.omenora.com
# Local development — replace with your machine's LAN IP:
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.X:3000

# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Google OAuth
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=YOUR_IOS_CLIENT_ID.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=YOUR_WEB_CLIENT_ID.apps.googleusercontent.com

# RevenueCat
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=

# Sentry error tracking — mobile DSN (public, bundled in app)
# Get from: unc-development.sentry.io/projects/omenora-mobile/keys/
EXPO_PUBLIC_SENTRY_DSN=

# Sentry source-map upload token — BUILD-TIME SECRET, never bundled
# Org-scoped auth token; same value as backend's SENTRY_AUTH_TOKEN
# Get from: unc-development.sentry.io/settings/auth-tokens/
# Required for EAS Build source map upload; not required for local dev
SENTRY_AUTH_TOKEN=
