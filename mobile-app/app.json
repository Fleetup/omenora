{
  "expo": {
    "name": "OMENORA",
    "slug": "omenora",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#050410",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#050410"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.omenora.app",
      "buildNumber": "1.0.0",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "remote-notification"
        ],
        "NSUserNotificationUsageDescription": "OMENORA sends daily cosmic insights and personalized notifications about your destiny readings.",
        "NSCameraUsageDescription": "This app does not require camera access.",
        "NSMicrophoneUsageDescription": "This app does not require microphone access.",
        "NSPhotoLibraryUsageDescription": "This app does not require photo library access.",
        "NSLocationWhenInUseUsageDescription": "OMENORA uses your location to provide accurate astrological calculations based on your birthplace.",
        "NSLocationAlwaysUsageDescription": "OMENORA uses your location to provide accurate astrological calculations based on your birthplace."
      },
      "config": {
        "usesNonExemptEncryption": false
      },
      "appStoreUrl": "https://apps.apple.com/app/omenora/id[YOUR_APPLE_ID]",
      "associatedDomains": [
        "applinks:omenora.com"
      ]
    },
    "android": {
      "package": "com.omenora.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#050410"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "playStoreUrl": "https://play.google.com/store/apps/details?id=com.omenora.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "https",
              "host": "omenora.com",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-apple-authentication",
      "expo-font",
      "expo-localization",
      "expo-notifications",
      "expo-splash-screen",
      "expo-system-ui",
      "expo-updates",
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "ios": {
            "newArchEnabled": true
          },
          "android": {
            "newArchEnabled": true
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "[YOUR_EAS_PROJECT_ID]"
      }
    },
    "owner": "omenora",
    "updates": {
      "url": "https://u.expo.dev/[YOUR_EAS_PROJECT_ID]",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "notification": {
      "icon": "./assets/notification-icon.png",
      "color": "#7B61FF",
      "iosDisplayInForeground": true,
      "androidMode": "default"
    },
    "scheme": "omenora",
    "deepLinking": true
  }
}
