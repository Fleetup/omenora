{
  "expo": {
    "name": "OMENORA",
    "slug": "omenora",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#15110D",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#15110D"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.omenora.app",
      "buildNumber": "1.0.0",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "remote-notification"
        ],
        "NSUserNotificationUsageDescription": "OMENORA sends daily cosmic insights and personalized notifications about your destiny readings.",
        "NSCameraUsageDescription": "This app does not require camera access.",
        "NSMicrophoneUsageDescription": "This app does not require microphone access.",
        "NSPhotoLibraryUsageDescription": "This app does not require photo library access.",
        "NSLocationWhenInUseUsageDescription": "OMENORA uses your location to provide accurate astrological calculations based on your birthplace.",
        "NSLocationAlwaysUsageDescription": "OMENORA uses your location to provide accurate astrological calculations based on your birthplace."
      },
      "config": {
        "usesNonExemptEncryption": false
      },
      "associatedDomains": [
        "applinks:omenora.com"
      ]
    },
    "android": {
      "package": "com.omenora.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#15110D"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "playStoreUrl": "https://play.google.com/store/apps/details?id=com.omenora.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "https",
              "host": "omenora.com",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-apple-authentication",
      ["@react-native-google-signin/google-signin", {
        "iosUrlScheme": "com.googleusercontent.apps.586013412793-e502c19tepphvu4ldqr62d28l9vi8sir"
      }],
      "expo-font",
      "expo-localization",
      ["expo-notifications", {
        "icon": "./assets/notification-icon.png",
        "color": "#7B61FF"
      }],
      "expo-splash-screen",
      "expo-system-ui",
      "expo-updates",
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "ios": {
            "newArchEnabled": true
          },
          "android": {
            "newArchEnabled": true
          }
        }
      ],
      "expo-secure-store",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "omenora-mobile",
          "organization": "unc-development"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "8f7dfec9-fd02-4ed9-85b9-8cdbeba7c6d3"
      }
    },
    "owner": "miroslavjokovic",
    "updates": {
      "url": "https://u.expo.dev/8f7dfec9-fd02-4ed9-85b9-8cdbeba7c6d3",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "scheme": "omenora"
  }
}
